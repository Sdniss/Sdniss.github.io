%-------------------------------------------------------------------------------
%	SECTION TITLE
%-------------------------------------------------------------------------------
\cvsection{((( data.section_title | tex_escape )))}

%-------------------------------------------------------------------------------
%	CONTENT
%-------------------------------------------------------------------------------
\begin{cventries}
((% for entry in data.entries %))
  \cventry
    {((( entry.degree | tex_escape )))} % Degree
    {((( entry.institution | tex_escape )))} % Institution
    {((( entry.location | tex_escape )))} % Location
    {((( entry.start_date | tex_escape ))) - ((( entry.end_date | tex_escape )))} % Date(s)
    {
      ((% if entry.cvitems %))
      \begin{cvitems} % Description(s) bullet points
      ((% for item in entry.cvitems %))
        \item {((( item | tex_escape )))}
      ((% endfor %))
      \end{cvitems}
      ((% endif %))
    }
  {}

  \vspace{0.2cm}
((% endfor %))
\end{cventries}
\vspace{-0.5cm}